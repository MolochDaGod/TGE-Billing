# ===========================================
# TGE-Billing Environment Variables
# ===========================================

# App
APP_URL=https://tgebilling.pro
PORT=5000
NODE_ENV=production
SESSION_SECRET=your-session-secret-here

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/dbname

# Google OAuth (for Google login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Drive / Cloud Storage (service account JSON key)
GOOGLE_CLOUD_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Stripe (payments)
STRIPE_SECRET_KEY=sk_live_...
VITE_STRIPE_PUBLIC_KEY=pk_live_...

# OpenAI (server-side AI agents - optional, Puter.js handles client-side AI)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# AgentMail (email sending)
AGENTMAIL_API_KEY=your-agentmail-key

# PayPal (optional)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Puter Worker (AI chat, lead scoring, content gen)
VITE_TGEWORKER_URL=https://tgeworker-xxxxx.puter.site
