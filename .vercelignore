# api/_lambda.ts is the esbuild entry — underscore prefix prevents Vercel
# from auto-detecting it as a serverless function endpoint.
# api/index.mjs is the pre-bundled output configured in vercel.json functions.

# Exclude local dev server files — not needed on Vercel
server/vite.ts
server/realtimeAI.ts
server/index.ts

# Exclude test/scripts
scripts/
workers/

# Exclude local build artifacts (dist/ is generated by vite build during vercel-build)
# Note: attached_assets/ and public/ must be present for the vite build to succeed
